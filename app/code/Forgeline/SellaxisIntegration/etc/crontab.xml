<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="default">
        <job name="forgeline_sellaxis_poll_orders" instance="Forgeline\SellaxisIntegration\Cron\PollOrders" method="execute">
            <schedule>*/5 * * * *</schedule>
        </job>
        <job name="forgeline_sellaxis_poll_inventory" instance="Forgeline\SellaxisIntegration\Cron\PollInventory" method="execute">
            <schedule>*/5 * * * *</schedule>
        </job>
    </group>
</config>
