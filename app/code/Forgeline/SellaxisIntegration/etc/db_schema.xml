<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="forgeline_sellaxis_events" resource="default" engine="innodb" comment="Sellaxis Webhook Events">
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false" identity="true" comment="Entity ID"/>
        <column xsi:type="varchar" name="event_id" nullable="false" length="255" comment="Stable Event ID"/>
        <column xsi:type="varchar" name="delivery_id" nullable="false" length="255" comment="Delivery ID"/>
        <column xsi:type="varchar" name="status" nullable="false" length="50" default="pending" comment="Processing Status"/>
        <column xsi:type="timestamp" name="occurred_at" on_update="false" nullable="false" comment="Event Occurrence Time"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Creation Time"/>
        
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="FORGELINE_SELLAXIS_EVENTS_EVENT_ID">
            <column name="event_id"/>
        </constraint>
        <index referenceId="FORGELINE_SELLAXIS_EVENTS_STATUS" indexType="btree">
            <column name="status"/>
        </index>
    </table>

    <table name="sales_order_item" resource="sales" comment="Sales Order Item">
        <column xsi:type="varchar" name="seller_id" nullable="true" length="255" comment="Sellaxis Seller ID"/>
        <column xsi:type="varchar" name="sellaxis_line_ref" nullable="true" length="255" comment="Sellaxis Line Reference"/>
        <column xsi:type="timestamp" name="last_event_occurred_at" nullable="true" comment="Last Event Occurred At Timestamp"/>
    </table>

    <table name="inventory_source_item" resource="default" comment="Inventory Source Item">
        <column xsi:type="int" name="sellaxis_version" nullable="true" comment="Sellaxis Inventory Version"/>
    </table>

    <table name="forgeline_offer_mapping" resource="default" engine="innodb" comment="Offer Mapping">
        <column xsi:type="varchar" name="offer_id" nullable="false" length="255" comment="Sellaxis Offer ID"/>
        <column xsi:type="varchar" name="seller_id" nullable="false" length="255" comment="Sellaxis Seller ID"/>
        <column xsi:type="varchar" name="seller_sku" nullable="false" length="255" comment="Seller SKU"/>
        <column xsi:type="int" name="magento_product_id" unsigned="true" nullable="false" comment="Magento Simple Product ID"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="offer_id"/>
        </constraint>
    </table>
</schema>
